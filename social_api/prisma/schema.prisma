// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

enum Provider {
  LOCAL
  GOOGLE
  FACEBOOK
  GITHUB
  APPLE
}

enum UserRole {
  USER
  ADMIN
}

enum VideoVisibility {
  PUBLIC
  PRIVATE
}

model User {
  id BigInt @id @default(autoincrement()) @db.UnsignedBigInt

  username    String @unique @db.VarChar(30)
  displayName String @db.VarChar(100)
  email       String @unique @db.VarChar(100)

  // IMPORTANT: nullable only for OAuth users
  passwordHash String? @db.VarChar(255)

  avatarUrl String? @db.VarChar(500)
  bio       String? @db.Text

  role       UserRole @default(USER)
  isVerified Boolean  @default(false)
  isActive   Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  videos   Video[]
  comments Comment[]
  likes    VideoLike[]
  saves    VideoSave[]

  followers Follow[] @relation("followers")
  following Follow[] @relation("following")

  refreshTokens      RefreshToken[]
  providers          UserProvider[]
  emailVerifications EmailVerification[]

  @@index([email])
  @@index([username])
}

model Video {
  id BigInt @id @default(autoincrement()) @db.UnsignedBigInt

  userId BigInt @db.UnsignedBigInt

  caption      String? @db.Text
  videoKey     String  @db.VarChar(255)
  videoUrl     String  @db.VarChar(500)
  thumbnailUrl String? @db.VarChar(500)

  duration Int @default(0)

  viewCount    BigInt @default(0)
  likeCount    BigInt @default(0)
  commentCount BigInt @default(0)
  saveCount    BigInt @default(0)

  visibility VideoVisibility @default(PUBLIC)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  comments Comment[]
  likes    VideoLike[]
  saves    VideoSave[]

  @@index([userId, createdAt]) // IMPORTANT for feed query
}

model Comment {
  id BigInt @id @default(autoincrement()) @db.UnsignedBigInt

  userId  BigInt @db.UnsignedBigInt
  videoId BigInt @db.UnsignedBigInt

  content String @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@index([videoId, createdAt])
}

model Follow {
  followerId  BigInt @db.UnsignedBigInt
  followingId BigInt @db.UnsignedBigInt

  createdAt DateTime @default(now())

  follower  User @relation("following", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("followers", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model VideoLike {
  userId  BigInt @db.UnsignedBigInt
  videoId BigInt @db.UnsignedBigInt

  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@id([userId, videoId])
  @@index([videoId])
}

model VideoSave {
  userId  BigInt @db.UnsignedBigInt
  videoId BigInt @db.UnsignedBigInt

  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@id([userId, videoId])
  @@index([videoId])
}

model RefreshToken {
  id BigInt @id @default(autoincrement())

  userId BigInt @db.UnsignedBigInt

  tokenHash String   @db.VarChar(255)
  expiresAt DateTime
  revoked   Boolean  @default(false)

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserProvider {
  id BigInt @id @default(autoincrement())

  userId BigInt @db.UnsignedBigInt

  provider       Provider
  providerUserId String   @db.VarChar(255)

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
}

model EmailVerification {
  id BigInt @id @default(autoincrement())

  userId BigInt @db.UnsignedBigInt

  codeHash  String   @db.VarChar(255) // băm mã OTP, KHÔNG lưu mã thô
  expiresAt DateTime
  attempts  Int      @default(0) // đếm số lần nhập sai để chống brute-force

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
